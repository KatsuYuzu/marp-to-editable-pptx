{
  "name": "marp-to-editable-pptx",
  "displayName": "Marp to Editable PPTX",
  "description": "Export Marp Markdown presentations to editable PowerPoint (.pptx)",
  "version": "1.0.0",
  "publisher": "KatsuYuzu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KatsuYuzu/marp-to-editable-pptx"
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "marp",
    "pptx",
    "powerpoint",
    "presentation",
    "markdown"
  ],
  "activationEvents": [
    "onCommand:marpToEditablePptx.export"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "marpToEditablePptx.export",
        "title": "Export to Editable PPTX",
        "category": "Marp"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build:prod",
    "build": "node src/native-pptx/scripts/generate-dom-walker-script.js && webpack --config webpack.config.js && node scripts/copy-marp-cli-assets.js",
    "build:prod": "node src/native-pptx/scripts/generate-dom-walker-script.js && webpack --config webpack.config.js --env production && node scripts/copy-marp-cli-assets.js",
    "compile": "tsc --noEmit",
    "test": "jest",
    "watch": "webpack --config webpack.config.js --watch"
  },
  "dependencies": {
    "@marp-team/marp-cli": "^4.3.1",
    "@puppeteer/browsers": "^2.13.0",
    "nanoid": "^5.1.6",
    "pptxgenjs": "^4.0.1",
    "puppeteer-core": "^24.40.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@types/jest": "^30.0.0",
    "@types/vscode": "~1.101.0",
    "@vscode/vsce": "^3.3.2",
    "esbuild": "^0.27.4",
    "esbuild-loader": "^4.4.2",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.0"
  }
}
